// Schema CSDL — website thông tin du lịch.
// Mô hình & quy ước: xem CLAUDE.md ("Mô hình dữ liệu cốt lõi").
// Engine: PostgreSQL (hỗ trợ native enum + String[]).

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [unaccent]
}

// ============================================================
// ENUMS
// ============================================================

enum PlaceKind {
  province // Tỉnh
  destination // Điểm đến lớn
}

// Cấu hình site dạng singleton (luôn 1 bản ghi id="singleton").
model SiteSetting {
  id           String   @id @default("singleton")
  siteName     String   @default("Halivivu")
  tagline      String?
  description  String? // mô tả meta (SEO)
  contactEmail String?
  facebookUrl  String?
  instagramUrl String?
  youtubeUrl   String?
  updatedAt    DateTime @updatedAt
}

enum PublishStatus {
  draft
  published
}

// Loại chủ đề diễn đàn cộng đồng (chỉ là nhãn phân loại, không cấu trúc riêng).
enum ThreadType {
  share // Chia sẻ trải nghiệm (đã đi)
  question // Hỏi đáp (chưa đi)
  trip // Tìm bạn đồng hành / rủ đi (sắp đi)
  discussion // Thảo luận chung
  sale // Rao dịch vụ — CHỈ CTV (SaleProfile) đã duyệt mới đăng được
}

// Trạng thái duyệt hồ sơ CTV (người bán). pending → approved | rejected.
enum SaleStatus {
  pending // vừa nộp, chờ staff duyệt
  approved // đã duyệt → công khai + có huy hiệu
  rejected // bị từ chối (kèm lý do)
}

// Loại kênh bị tố lừa đảo (công cụ kiểm tra uy tín).
enum ScamChannel {
  phone // SĐT / Zalo
  facebook // link/trang Facebook
  website // website
  bank_account // số tài khoản ngân hàng
}

// Trạng thái báo cáo lừa đảo. Chỉ confirmed mới hiện/đếm công khai.
enum ScamReportStatus {
  pending // chờ kiểm duyệt
  confirmed // đã xác nhận (hiện công khai)
  rejected // bác bỏ
}

// Loại thông báo (tương tác lên nội dung của người nhận).
enum NotificationType {
  thread_comment // bình luận bài cộng đồng của bạn
  thread_reply // trả lời bình luận cộng đồng của bạn
  thread_like // thích bài cộng đồng của bạn
  reply_like // thích bình luận cộng đồng của bạn
  blog_reply // trả lời bình luận blog của bạn
  sale_approved // hồ sơ CTV được duyệt
  sale_rejected // hồ sơ CTV bị từ chối
}

// Cảm nhận chung của một review điểm đến (chọn 1) — thang 4 mức thay cho số sao.
enum ReviewStance {
  love // tuyệt vời, muốn quay lại
  worthOnce // đáng đi một lần
  meh // không có gì đặc biệt
  bad // thất vọng, không nên đi
}

/// Mức giá tương đối: budget=$ · moderate=$$ · premium=$$$ · luxury=$$$$
enum PriceRange {
  budget
  moderate
  premium
  luxury
}

enum SpotCategory {
  beach
  mountain
  waterfall
  lake
  cave
  temple
  viewpoint
  village
  island
  park
  other
}

enum EateryCategory {
  local
  seafood
  streetfood
  vegetarian
  cafe
  bbq
  other
}

// Bữa/khung giờ ăn — để khách lọc & xếp lịch ăn theo ngày.
enum Meal {
  breakfast // sáng
  lunch // trưa
  dinner // tối
  cafe // cà phê / giải khát
  snack // ăn vặt
}

enum AccommodationCategory {
  hotel
  homestay
  resort
  hostel
  guesthouse
  villa
}

enum ActivityCategory {
  adventure
  nature
  culture
  relax
  water
  food
  other
}

enum ActivityDifficulty {
  easy // dễ
  moderate // vừa
  hard // khó
}

// Mức độ hoạt động (xem CLAUDE.md "Spot vs Activity"):
// experience = trải nghiệm/dịch vụ lớn (tour, lớp học) — nội dung dày, đặt chỗ;
// common     = hoạt động lặp ở nhiều spot, nội dung riêng theo từng spot (qua SpotActivity);
// spot       = đặc trưng nhỏ chỉ ở 1 spot, KHÔNG hiện ở cấp điểm đến.
enum ActivityKind {
  experience
  common
  spot
}

enum TransportDirection {
  getTo // đến nơi từ bên ngoài
  getAround // di chuyển tại chỗ
}

enum TransportMode {
  car
  bus
  train
  plane
  boat
  motorbike
  taxi
  grab
  bike
  walk
  cyclo
  shuttle
  other
}

enum UserRole {
  user
  editor
  admin
}

// ============================================================
// AUTH (NextAuth v5 / Prisma adapter) + role
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(user)
  homeProvince  String? // tỉnh/thành người dùng chọn (nơi ở / xuất phát) — cá nhân hoá sau này

  accounts Account[]
  sessions Session[]
  posts    Post[] // bài blog do user này viết
  likes    PostLike[] // bài đã tim
  comments Comment[] // bình luận đã viết

  threads       Thread[] // chủ đề cộng đồng đã đăng
  threadReplies ThreadReply[] // trả lời trong cộng đồng
  threadLikes   ThreadLike[] // chủ đề/trả lời đã thích

  notifications      Notification[] @relation("NotifRecipient") // thông báo nhận
  notificationsActed Notification[] @relation("NotifActor") // thông báo do mình gây ra

  checkIns CheckIn[] // các điểm đến/tỉnh đã đánh dấu "đã đến"
  reviews  Review[] // đánh giá điểm đến đã viết

  saleProfile   SaleProfile?  @relation("SaleOwner") // hồ sơ CTV (nếu có) — đăng ký làm người bán
  salesReviewed SaleProfile[] @relation("SaleReviewer") // hồ sơ CTV mình đã duyệt (staff)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// PLACE — gộp Tỉnh + Điểm đến lớn (tự tham chiếu cha-con)
// Ràng buộc (app-level): province ⇒ parentId=null;
// destination ⇒ parent là province. Giữ đúng 2 mức.
// ============================================================

model Place {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  kind        PlaceKind
  tagline     String? // câu slogan ngắn hiển thị dưới tên (khác description)
  description String?

  // Vị trí hành chính (provinces.open-api.vn v1 — địa chính cũ, 3 cấp:
  // tỉnh → quận/huyện → phường/xã). Lưu cả code (để truy vấn/relink lại) và
  // name (denormalized để hiển thị không cần gọi API).
  provinceCode Int?
  provinceName String?
  districtCode Int?
  districtName String?
  wardCode     Int?
  wardName     String?

  parentId String?
  parent   Place?  @relation("PlaceTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Place[] @relation("PlaceTree")

  // Listing con (gắn qua placeId)
  activities     Activity[]
  spots          Spot[]
  specialties    Specialty[]
  eateries       Eatery[]
  accommodations Accommodation[]
  transports     Transport[]

  images       Image[]
  videos       PlaceVideo[] // video TikTok giới thiệu (hiển thị ở hero + modal)
  postRefs     PostRef[]
  threads      Thread[] // chủ đề cộng đồng gắn điểm đến này
  saleProfiles SaleProfile[]   @relation("SaleAreas") // CTV phục vụ nơi này (M:N)
  viewStats    PlaceViewStat[] // lượt xem theo ngày (để lọc trending)
  checkIns     CheckIn[] // người dùng đã đánh dấu "đã đến" nơi này
  reviews      Review[] // đánh giá của Vivu-er (chỉ điểm đến lớn)

  tags String[] @default([])

  // "Trước khi đi": danh sách {label, value} biên tập trong CMS (hiển thị cạnh giới thiệu)
  quickInfo Json?

  // AdminFields
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0) // điểm tổng hợp (chưa dùng) — xem viewCount cho lượt xem thật
  viewCount   Int           @default(0) // tổng lượt xem all-time (tự tăng mỗi truy cập)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([kind])
  @@index([parentId])
  @@index([status])
}

// Lượt xem Place gộp theo ngày: 1 dòng / place / ngày.
// "trending N ngày" = sum(count) where date >= today - N. Gọn & lọc theo thời gian được.
model PlaceViewStat {
  id      String   @id @default(cuid())
  placeId String
  place   Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date
  count   Int      @default(0)

  @@unique([placeId, date])
  @@index([date])
}

// CheckIn — người dùng đánh dấu "đã đến" một Place (tỉnh hoặc điểm đến lớn).
// Propagate: check-in điểm đến con tự tạo CheckIn cho tỉnh cha (auto=true);
// bỏ check-in chỉ gỡ tỉnh auto khi không còn con nào được check-in. Tỉnh đánh
// dấu trực tiếp (auto=false) luôn giữ. Thống kê X/63 đếm CheckIn của tỉnh.
model CheckIn {
  id      String  @id @default(cuid())
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId String
  place   Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  auto    Boolean @default(false) // true = tỉnh tự đánh dấu do check-in điểm đến con

  createdAt DateTime @default(now())

  @@unique([userId, placeId])
  @@index([userId])
  @@index([placeId])
}

// Review điểm đến — CHỈ kind=destination (validate ở app). Gate app-level:
// author phải có CheckIn với place. Cảm nhận chung (stance, bắt buộc) + nhãn
// điểm cộng/cần lưu ý (vocab định nghĩa trong code, lưu String[]) + nội dung viết
// (tùy chọn). Hiện ngay; staff ẩn nếu cần. 1 review/người/điểm đến, sửa được.
model Review {
  id       String @id @default(cuid())
  placeId  String
  place    Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  stance     ReviewStance
  highlights String[] @default([]) // nhãn "điểm cộng" đã chọn
  caveats    String[] @default([]) // nhãn "cần lưu ý" đã chọn
  content    String? // nội dung viết (tùy chọn)

  isHidden Boolean @default(false) // staff ẩn khỏi công khai (không tính vào tổng hợp)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([placeId, authorId])
  @@index([placeId])
  @@index([authorId])
}

// ============================================================
// LISTINGS
// ============================================================

model Activity {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String? // mô tả ngắn (meta SEO, card, excerpt hero)
  content     String? // thân bài chi tiết: HTML (rich text) — tùy chọn (chủ yếu cho experience)
  kind        ActivityKind      @default(common)
  category    ActivityCategory?

  // Đơn vị khai thác / đặt chỗ (inline, không tách entity Provider)
  operatorName String?
  bookingUrl   String?
  phone        String?
  website      String?
  priceRange   PriceRange? // (giữ cho dữ liệu cũ; form dùng ticketTiers)
  ticketFree   Boolean     @default(false) // miễn phí tham gia
  ticketTiers  Json? // [{ label, price, note }] — giá VND, null/0 = miễn phí (xem lib/tickets)

  // Thực tế trải nghiệm (xem CLAUDE.md "Spot vs Activity")
  difficulty   ActivityDifficulty?
  durationText String? // "nửa ngày", "2N1Đ", "~2 giờ"
  seasonText   String? // "tháng 9–11", "săn mây mùa thu"

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  spotLinks SpotActivity[] // M:N qua bảng nối (mang nội dung riêng theo spot)

  images   Image[]
  postRefs PostRef[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([category])
  @@index([status])
}

model Spot {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String? // mô tả ngắn / mở bài (meta SEO, card, excerpt hero)
  category    SpotCategory?

  // PlaceableFields (cơ sở thực địa)
  address      String?
  lat          Float?
  lng          Float?
  openingHours String?
  phone        String?
  website      String?
  bookingUrl   String?
  mapUrl       String? // link bản đồ (Google Maps…)
  priceRange   PriceRange?

  // Vị trí hành chính (provinces.open-api.vn v1 — địa chính cũ, 3 cấp:
  // tỉnh → quận/huyện → phường/xã). Lưu cả code (để tải cấp con) và name (hiển thị).
  provinceCode Int?
  provinceName String?
  districtCode Int?
  districtName String?
  wardCode     Int?
  wardName     String?

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  // Thực tế về chỗ (xem CLAUDE.md "Spot vs Activity")
  bestTime     String? // mùa/giờ đẹp nhất — ngắn, cho chip hero ("sáng sớm")
  bestTimeNote String? // diễn giải "khi nào đẹp nhất" — đoạn cho mục riêng
  ticketFree   Boolean @default(false) // miễn phí vào cửa
  ticketTiers  Json? // [{ label, price, note }] — giá VND, null/0 = miễn phí (xem lib/tickets)
  ticketInfo   String? // ghi chú vé chung (giờ bán vé, ưu đãi…)
  notice       String? // cảnh báo truy cập: "Tạm đóng", "Cần xin phép leo"

  // Nội dung biên tập có khuôn (thay rich-text tự do)
  gettingThere String? // cách đến riêng cho địa điểm này (hướng dẫn, mẹo đường đi)
  tips         String[]        @default([]) // kinh nghiệm / mẹo — mỗi phần tử một gạch đầu dòng
  highlights   SpotHighlight[] // điểm nhấn (title + body + ảnh), sắp theo order

  activityLinks SpotActivity[] // M:N qua bảng nối (mang nội dung riêng theo spot)

  images   Image[]
  postRefs PostRef[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([category])
  @@index([status])
}

// Bảng nối Spot ↔ Activity mang nội dung RIÊNG theo từng spot.
// experience: blurb thường để trống (dùng content chung của Activity);
// common/spot: blurb + ảnh riêng cho spot này ("tắm biển ở Hòn Rơm"…).
model SpotActivity {
  id         String   @id @default(cuid())
  spotId     String
  spot       Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  blurb      String? // mô tả hoạt động này TẠI spot này
  imageUrl   String?
  imageAlt   String?

  @@unique([spotId, activityId])
  @@index([spotId])
  @@index([activityId])
}

// Điểm nhấn của một địa điểm — mỗi mục có tiêu đề, mô tả và ảnh riêng.
model SpotHighlight {
  id       String  @id @default(cuid())
  spotId   String
  spot     Spot    @relation(fields: [spotId], references: [id], onDelete: Cascade)
  order    Int     @default(0)
  title    String
  body     String? // mô tả ngắn cho điểm nhấn
  imageUrl String? // ảnh minh hoạ (URL)
  imageAlt String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spotId])
}

model Specialty {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  eateries Eatery[] @relation("SpecialtyEateries") // M:N

  images   Image[]
  postRefs PostRef[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([status])
}

model Eatery {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  category    EateryCategory?

  // PlaceableFields
  address      String?
  lat          Float?
  lng          Float?
  openingHours String?
  phone        String?
  website      String?
  bookingUrl   String?
  mapUrl       String? // link bản đồ (Google Maps…)

  // Vị trí hành chính (tự điền theo địa điểm cha; xem CLAUDE.md). Lưu cả code + name.
  provinceCode Int?
  provinceName String?
  districtCode Int?
  districtName String?
  wardCode     Int?
  wardName     String?

  meals  Meal[] // bữa phù hợp (sáng/trưa/tối/cà phê/ăn vặt) — để lọc
  notice String? // cảnh báo: "nghỉ thứ 2", "hết sớm", "chỉ bán sáng"

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  specialties Specialty[] @relation("SpecialtyEateries") // M:N

  images   Image[]
  postRefs PostRef[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([category])
  @@index([status])
}

// Định vị: DANH BẠ chỗ ở ĐÃ XÁC MINH CHÍNH CHỦ — không phải OTA (xem CLAUDE.md
// "Đặc sản vs Quán ăn" / "Nơi lưu trú"). Giá trị lõi = kênh liên hệ thật đã kiểm
// chứng + huy hiệu xác minh + cảnh báo chống lừa cọc. KHÔNG làm đặt phòng/calendar.
model Accommodation {
  id          String                 @id @default(cuid())
  slug        String                 @unique
  name        String
  description String?
  category    AccommodationCategory?

  // PlaceableFields
  address      String?
  lat          Float?
  lng          Float?
  openingHours String?
  phone        String?
  website      String?
  bookingUrl   String?

  // Kênh liên hệ chính chủ (thực tế VN: Zalo là kênh chốt phòng chính)
  zalo        String? // SĐT/link Zalo chính chủ
  facebookUrl String? // page/profile chính chủ (để khách đối chiếu, tránh page nhái)

  // Xác minh chính chủ — lõi định vị (FB group KHÔNG cung cấp được)
  isVerified   Boolean   @default(false) // đã xác minh đây là chủ thật
  verifiedAt   DateTime? // mốc xác minh (audit)
  verifiedNote String? // nội bộ: cách xác minh (gọi điện, gặp trực tiếp…) — KHÔNG hiện public

  // An toàn giao dịch / chống lừa cọc
  depositPolicy String? // chính sách cọc bằng lời ("Cọc 50% qua chính chủ", "Không cọc trước")
  notice        String? // cảnh báo: "Chỉ liên hệ qua kênh hiển thị tại đây", "Hết phòng mùa lễ"…

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  images   Image[]
  postRefs PostRef[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([category])
  @@index([status])
  @@index([isVerified])
}

// Transport: hiển thị INLINE trên trang Place — không slug, không trang chi tiết,
// không là đích PostRef. Vẫn lưu DB và có thể có ảnh.
model Transport {
  id          String             @id @default(cuid())
  name        String
  description String?
  direction   TransportDirection
  mode        TransportMode

  fromName   String? // chỉ getTo
  duration   String?
  distanceKm Float?
  priceFrom  Int?
  priceTo    Int?
  currency   String? @default("VND")

  operatorName String?
  bookingUrl   String?

  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  images Image[]

  status      PublishStatus @default(draft)
  publishedAt DateTime?
  order       Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([placeId])
  @@index([direction])
  @@index([status])
}

// ============================================================
// IMAGE — một ảnh thuộc đúng MỘT chủ sở hữu (exclusive arc:
// đúng một trong các FK dưới đây được set). Cascade theo chủ.
// ============================================================

model Image {
  id      String  @id @default(cuid())
  url     String
  alt     String?
  caption String?
  credit  String?
  order   Int     @default(0)
  isCover Boolean @default(false)

  placeId         String?
  place           Place?         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  activityId      String?
  activity        Activity?      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  spotId          String?
  spot            Spot?          @relation(fields: [spotId], references: [id], onDelete: Cascade)
  specialtyId     String?
  specialty       Specialty?     @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  eateryId        String?
  eatery          Eatery?        @relation(fields: [eateryId], references: [id], onDelete: Cascade)
  accommodationId String?
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  transportId     String?
  transport       Transport?     @relation(fields: [transportId], references: [id], onDelete: Cascade)
  postId          String?
  post            Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  threadId        String?
  thread          Thread?        @relation(fields: [threadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([placeId])
  @@index([activityId])
  @@index([spotId])
  @@index([specialtyId])
  @@index([eateryId])
  @@index([accommodationId])
  @@index([transportId])
  @@index([postId])
  @@index([threadId])
}

// Video TikTok gắn vào Place (giới thiệu điểm đến). Chỉ lưu videoId của TikTok
// (vd 7486790456437787925) + caption; thumbnail lấy runtime qua oEmbed.
model PlaceVideo {
  id        String   @id @default(cuid())
  placeId   String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  videoId   String // ID video TikTok
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placeId])
}

// ============================================================
// BLOG
// ============================================================

model Post {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  excerpt  String?
  content  String // HTML (rich text TipTap)
  category String? // phân loại bài (editorial, để linh hoạt): cam-nang | am-thuc | ...

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  refs     PostRef[]
  images   Image[]
  likes    PostLike[]
  comments Comment[]

  tags        String[]      @default([])
  status      PublishStatus @default(draft)
  publishedAt DateTime?
  isFeatured  Boolean       @default(false)
  order       Int?
  popularity  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([authorId])
  @@index([status])
}

// PostRef — liên kết bài viết tới Place/Listing (đích có trang).
// Exclusive arc: đúng một trong các FK target được set. (Không gồm Transport.)
model PostRef {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  order  Int    @default(0)

  placeId         String?
  place           Place?         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  activityId      String?
  activity        Activity?      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  spotId          String?
  spot            Spot?          @relation(fields: [spotId], references: [id], onDelete: Cascade)
  specialtyId     String?
  specialty       Specialty?     @relation(fields: [specialtyId], references: [id], onDelete: Cascade)
  eateryId        String?
  eatery          Eatery?        @relation(fields: [eateryId], references: [id], onDelete: Cascade)
  accommodationId String?
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([placeId])
  @@index([activityId])
  @@index([spotId])
  @@index([specialtyId])
  @@index([eateryId])
  @@index([accommodationId])
}

// PostLike — "tim" bài viết (M:N User↔Post). Mỗi user tim 1 bài tối đa 1 lần.
model PostLike {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

// Comment — thảo luận dưới bài viết. Lồng 1 cấp: reply gắn parentId trỏ tới
// một comment gốc (parentId = null). Không cho reply của reply (validate ở app).
model Comment {
  id       String @id @default(cuid())
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content  String

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

// ============================================================
// CỘNG ĐỒNG (diễn đàn UGC) — Thread + ThreadReply + ThreadLike
// Khác blog: do người dùng đăng, hiện ngay; staff ghim/khóa/ẩn.
// Ảnh để inline trong body (rich-text qua Jodit/UploadThing) — không entity riêng.
// ============================================================
model Thread {
  id    String     @id @default(cuid())
  slug  String     @unique
  title String? // tiêu đề tùy chọn (bài kiểu Facebook không cần)
  body  String // nội dung dạng văn bản (status), hiển thị whitespace-pre-wrap
  type  ThreadType @default(discussion)

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  placeId String? // (tùy chọn) gắn điểm đến để lọc & cross-link
  place   Place?  @relation(fields: [placeId], references: [id], onDelete: SetNull)

  tags String[] @default([])

  isPinned Boolean @default(false) // staff ghim lên đầu
  isLocked Boolean @default(false) // khóa không cho trả lời
  isHidden Boolean @default(false) // staff ẩn khỏi công khai

  replyCount     Int      @default(0) // denormalize để list nhanh
  lastActivityAt DateTime @default(now()) // sắp theo "hoạt động gần đây"

  replies ThreadReply[]
  likes   ThreadLike[]
  images  Image[] // ảnh đính kèm (bài kiểu Facebook)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([placeId])
  @@index([authorId])
  @@index([isPinned, lastActivityAt])
}

model ThreadReply {
  id       String @id @default(cuid())
  threadId String
  thread   Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content  String // văn bản thường (hiển thị whitespace-pre-wrap)

  parentId String?
  parent   ThreadReply?  @relation("ThreadReplyChildren", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ThreadReply[] @relation("ThreadReplyChildren")
  likes    ThreadLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([parentId])
  @@index([authorId])
}

// Thích/hữu ích cho chủ đề HOẶC trả lời (exclusive arc: đúng 1 trong 2 FK).
model ThreadLike {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  threadId String?
  thread   Thread?      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  replyId  String?
  reply    ThreadReply? @relation(fields: [replyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([threadId, userId])
  @@unique([replyId, userId])
  @@index([userId])
}

// Hồ sơ CTV / người bán (sale) — DANH BẠ người bán ĐÃ XÁC MINH, song song với
// Accommodation. Người dùng tự đăng ký (pending) → staff duyệt (approved) → hiện
// huy hiệu + được đăng Thread(type=sale) + có trang cá nhân /sale/[slug].
// 1:1 với User: sự tồn tại của hồ sơ = "là sale"; status=approved = huy hiệu công khai.
model SaleProfile {
  id     String @id @default(cuid())
  slug   String @unique
  userId String @unique
  user   User   @relation("SaleOwner", fields: [userId], references: [id], onDelete: Cascade)

  displayName String
  bio         String?
  services    String[] @default([]) // bán gì: tour | phong | ve | combo | thue-xe | tour-tu-thiet-ke ...

  // Kênh liên hệ (như Accommodation) — được đối chiếu whitelist khi kiểm tra uy tín
  zalo        String?
  phone       String?
  facebookUrl String?
  website     String?

  avatarUrl String? // ảnh đại diện công khai (fallback User.image)

  // Duyệt / xác minh
  status            SaleStatus @default(pending)
  verifiedAt        DateTime? // mốc được duyệt (approved)
  reVerifyDueAt     DateTime? // hạn tái xác minh (uy tín cũ đi)
  verificationLevel String? // basic | standard | high (theo SOP)
  verifiedNote      String? // NỘI BỘ: đã xác minh gì — KHÔNG hiện public
  evidenceUrls      String[]   @default([]) // NỘI BỘ: ảnh bằng chứng (GPKD, MST…) — chỉ staff xem
  rejectReason      String? // lý do từ chối (hiện cho chính chủ)
  reviewedById      String?
  reviewedBy        User?      @relation("SaleReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  notice String? // cảnh báo an toàn hiển thị cho khách

  areas Place[] @relation("SaleAreas") // khu vực phục vụ (M:N)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Báo cáo lừa đảo từ cộng đồng (blacklist) — cho công cụ kiểm tra uy tín.
// BẮT BUỘC bằng chứng + kiểm duyệt; chỉ confirmed mới hiện/đếm công khai.
// reporterId/reviewedById lưu dạng cột thường (không FK) để đỡ ràng buộc.
model ScamReport {
  id              String           @id @default(cuid())
  channel         ScamChannel
  valueNorm       String // giá trị đã chuẩn hoá — để đối chiếu khi tra
  valueRaw        String // giá trị gốc người báo nhập
  reason          String? // lý do ngắn (vd "lừa cọc", "page nhái")
  description     String? // mô tả chi tiết sự việc
  evidenceUrls    String[]         @default([]) // ảnh bằng chứng (bắt buộc ≥1)
  reporterId      String? // user báo cáo (nếu đăng nhập)
  reporterContact String? // liên hệ người báo (nếu ẩn danh)
  status          ScamReportStatus @default(pending)
  reviewedById    String? // staff đã kiểm duyệt
  reviewNote      String? // ghi chú kiểm duyệt (nội bộ)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([channel, valueNorm])
  @@index([status])
}

// Thông báo khi có người tương tác lên nội dung của người nhận.
model Notification {
  id      String           @id @default(cuid())
  userId  String // người nhận
  user    User             @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId String // người gây ra tương tác
  actor   User             @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  type    NotificationType

  url     String // đích khi bấm vào (vd /cong-dong/<slug>)
  excerpt String? // trích đoạn nội dung liên quan (để hiển thị ngữ cảnh)

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
